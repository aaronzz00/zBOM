# .env.prod.example — Production Environment Variables Template
# Copy this file to .env.prod and fill in your actual values.
# NEVER commit .env.prod to git.
#
# Usage:
#   cp .env.prod.example .env.prod
#   # Edit .env.prod with real credentials
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# ─────────────────────────────────────────────
# PostgreSQL Database Configuration
# ─────────────────────────────────────────────

# Database username (default: zbom)
POSTGRES_USER=zbom

# REQUIRED: Strong database password — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Database name (default: zbom)
POSTGRES_DB=zbom

# ─────────────────────────────────────────────
# Application Secrets
# ─────────────────────────────────────────────

# REQUIRED: Session secret for cookie signing — generate with: openssl rand -base64 64
SESSION_SECRET=CHANGE_ME_64_CHAR_SESSION_SECRET

# REQUIRED: Encryption key for AI credentials — generate with: openssl rand -hex 32
AI_CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# ─────────────────────────────────────────────
# Networking
# ─────────────────────────────────────────────

# Public port for the Nginx web server (default: 80)
# Change to 8080 if port 80 is occupied or behind a load balancer
WEB_PORT=80
