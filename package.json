{
  "name": "zbom",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx server/index.ts",
    "build:api": "tsc -p server/tsconfig.json --noEmit",
    "test:api": "vitest run --config vitest.api.config.ts --reporter=verbose",
    "prisma:generate": "DATABASE_URL=file:dev.db prisma generate --schema server/db/schema.prisma",
    "prisma:migrate": "npm run prisma:apply",
    "prisma:apply": "DATABASE_URL=file:dev.db prisma db execute --schema server/db/schema.prisma --file server/db/migrations/20260607223000_init/migration.sql",
    "prisma:seed": "DATABASE_URL=file:dev.db tsx server/db/seed.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test:core-browser": "node scripts/core-browser-qa.mjs",
    "db:use-sqlite": "node scripts/switch-db-provider.js sqlite && npm run prisma:generate",
    "db:use-postgres": "node scripts/switch-db-provider.js postgresql && npm run prisma:generate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.18.0",
    "@tanstack/react-virtual": "^3.13.18",
    "fastify": "^5.8.5",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.6.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.4.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.6",
    "prisma": "^6.18.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.17"
  }
}
